# =============================================================
#  Sanos & Salvos — Variables de entorno
#  Copia este archivo como .env y reemplaza los valores
#  NUNCA subas .env al repositorio (está en .gitignore)
# =============================================================

# ── PostgreSQL (DB de escritura) ────────────────────────────
POSTGRES_DB=sanos_salvos
POSTGRES_USER=ss_admin
POSTGRES_PASSWORD=CAMBIAR_EN_PRODUCCION

# ── MongoDB (DB de lectura) ──────────────────────────────────
MONGO_ROOT_USER=ss_admin
MONGO_ROOT_PASSWORD=CAMBIAR_EN_PRODUCCION
MONGO_DB=sanos_salvos_read

# ── MinIO (almacenamiento de fotos) ─────────────────────────
MINIO_ROOT_USER=ss_minio_admin
MINIO_ROOT_PASSWORD=CAMBIAR_EN_PRODUCCION
MINIO_BUCKET_FOTOS=fotos-mascotas

# ── Google OAuth2 ────────────────────────────────────────────
# Obtener en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/oauth2/callback/google

# ── JWT ──────────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_SECRET=CAMBIAR_EN_PRODUCCION_GENERAR_CON_OPENSSL
JWT_EXPIRATION_MS=86400000
# 86400000 ms = 24 horas

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=ss-consumers

# ── Entorno general ──────────────────────────────────────────
APP_ENV=development
# Opciones: development | production

# ── URLs de servicios (para uso desde los microservicios) ───
POSTGRES_URL=jdbc:postgresql://postgres:5432/${POSTGRES_DB}
MONGO_URL=mongodb://${MONGO_ROOT_USER}:${MONGO_ROOT_PASSWORD}@mongodb:27017/${MONGO_DB}?authSource=admin
MINIO_ENDPOINT=http://minio:9000
DEBEZIUM_URL=http://debezium:8083
