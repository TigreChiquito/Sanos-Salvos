---
// src/components/Navbar.astro
---

<nav class="nav">
  <a href="/" class="logo">
    <span class="logo-text">Sanos &amp; Salvos</span>
  </a>
  <ul class="nav-links">
    <li><a href="/">Cómo funciona</a></li>
    <li><a href="/mapa">Mapa</a></li>
    <li><a href="/nosotros">Nosotros</a></li>
    <!-- guest -->
    <li data-auth="guest">
      <a href="/acceder" class="nav-acceder">Acceder</a>
    </li>
    <!-- logged-in -->
    <li data-auth="user">
      <a href="/reportar" class="nav-cta">Reportar ahora</a>
    </li>
    <li data-auth="user" class="nav-bell-wrap">
      <button class="nav-bell" id="nav-bell-btn" aria-label="Notificaciones" aria-expanded="false">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        <span class="bell-badge" id="nav-bell-badge" style="display:none">0</span>
      </button>
      <div class="notif-dropdown" id="nav-notif-dropdown">
        <div class="notif-header">
          <span class="notif-title">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            Notificaciones
          </span>
          <button class="notif-read-all" id="nav-read-all">Leer todas</button>
        </div>
        <div class="notif-list" id="nav-notif-list">
          <div class="notif-empty">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            Sin notificaciones por ahora
          </div>
        </div>
      </div>
    </li>
    <li data-auth="user" class="nav-avatar-wrap">
      <button
        class="nav-avatar"
        id="nav-avatar-btn"
        aria-label="Menú de usuario"
        aria-expanded="false"
      >
        <img id="nav-avatar-img" src="" alt="" class="nav-avatar-img" style="display:none" />
        <span id="nav-initials">??</span>
      </button>
      <div class="nav-user-dropdown" id="nav-user-dropdown">
        <span class="dropdown-name" id="nav-user-name"></span>
        <hr class="dropdown-divider" />
        <a class="dropdown-item" href="/perfil">Mi perfil</a>
        <button class="dropdown-logout" id="nav-logout-btn"
          >Cerrar sesión</button
        >
      </div>
    </li>
  </ul>
  <!-- Mobile hamburger -->
  <button
    class="nav-burger"
    aria-label="Menú"
    aria-expanded="false"
    id="nav-burger"
  >
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- Mobile menu -->
<div class="nav-mobile" id="nav-mobile">
  <a href="#como-funciona">Cómo funciona</a>
  <a href="/mapa">Mapa</a>
  <a href="/nosotros">Nosotros</a>
  <a href="/acceder" data-auth="guest">Acceder</a>
  <a href="/reportar" data-auth="user" class="nav-cta-mobile">Reportar ahora</a>
  <button
    data-auth="user"
    class="nav-cta-mobile mobile-logout"
    id="nav-mobile-logout">Cerrar sesión</button
  >
</div>

<style>
  .nav {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.6rem 3rem;
    animation: fadeDown 0.8s ease both;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: white;
  }
  .logo-mark {
    width: 36px;
    height: 36px;
    background: var(--terra);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    box-shadow: 0 2px 12px rgba(196, 92, 58, 0.5);
  }
  .logo-text {
    font-family: "Fraunces", serif;
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
  }
  .nav-links a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: white;
  }

  .nav-acceder {
    color: rgba(255, 255, 255, 0.85) !important;
    border: 1.5px solid rgba(255, 255, 255, 0.3);
    padding: 0.45rem 1.1rem;
    border-radius: 999px;
    font-weight: 700 !important;
    transition:
      background 0.2s,
      border-color 0.2s,
      color 0.2s !important;
  }
  .nav-acceder:hover {
    background: rgba(255, 255, 255, 0.12) !important;
    border-color: rgba(255, 255, 255, 0.6) !important;
    color: white !important;
  }

  .nav-cta {
    background: var(--terra) !important;
    color: white !important;
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    font-weight: 700 !important;
    box-shadow: 0 2px 16px rgba(196, 92, 58, 0.45);
    transition:
      background 0.2s,
      transform 0.15s !important;
  }
  .nav-cta:hover {
    background: var(--terra-d) !important;
    transform: translateY(-1px);
  }

  /* Notification bell */
  .nav-bell-wrap { position: relative; }
  .nav-bell {
    position: relative;
    background: none; border: none; cursor: pointer;
    color: rgba(255,255,255,.65); padding: 6px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 8px; transition: color .2s, background .2s;
  }
  .nav-bell:hover { color: white; background: rgba(255,255,255,.08); }
  .bell-badge {
    position: absolute; top: -2px; right: -4px;
    background: #C45C3A; color: white;
    font-size: .58rem; font-weight: 900;
    min-width: 17px; height: 17px; border-radius: 999px;
    display: flex; align-items: center; justify-content: center;
    padding: 0 4px; pointer-events: none;
    border: 2px solid transparent;
  }

  /* Panel ----------------------------------------------------------------- */
  .notif-dropdown {
    display: none; flex-direction: column;
    position: absolute; top: calc(100% + .75rem); right: -12px;
    background: #160A05;
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 16px; overflow: hidden;
    width: 360px;
    box-shadow: 0 20px 60px rgba(0,0,0,.7), 0 0 0 1px rgba(196,92,58,.08);
    z-index: 100;
  }
  .notif-dropdown.open {
    display: flex;
    animation: notifSlideIn .18s ease both;
  }
  @keyframes notifSlideIn {
    from { opacity: 0; transform: translateY(-6px) scale(.98); }
    to   { opacity: 1; transform: translateY(0)   scale(1);    }
  }

  /* Header ---------------------------------------------------------------- */
  .notif-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 1.1rem .75rem;
    background: rgba(255,255,255,.03);
    border-bottom: 1px solid rgba(255,255,255,.07);
  }
  .notif-title {
    font-size: .88rem; font-weight: 800; letter-spacing: .01em;
    color: #F5EAE0;
    display: flex; align-items: center; gap: .45rem;
  }
  .notif-title svg { opacity: .6; }
  .notif-read-all {
    background: rgba(196,92,58,.15); border: 1px solid rgba(196,92,58,.3);
    border-radius: 6px; cursor: pointer;
    font-family: 'Nunito', sans-serif; font-size: .71rem; font-weight: 700;
    color: #F0B89A; padding: .25rem .65rem; transition: background .15s, color .15s;
    white-space: nowrap;
  }
  .notif-read-all:hover { background: rgba(196,92,58,.3); color: white; }

  /* List ------------------------------------------------------------------ */
  .notif-list {
    overflow-y: auto; max-height: 400px;
    scrollbar-width: thin; scrollbar-color: rgba(255,255,255,.1) transparent;
  }
  .notif-list::-webkit-scrollbar { width: 4px; }
  .notif-list::-webkit-scrollbar-track { background: transparent; }
  .notif-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,.1); border-radius: 4px; }

  .notif-empty {
    display: flex; flex-direction: column; align-items: center; gap: .6rem;
    padding: 2.5rem 1rem; color: rgba(245,220,200,.35);
    font-size: .83rem; text-align: center;
  }
  .notif-empty svg { opacity: .25; }

  /* Item — :global() porque se insertan dinámicamente con innerHTML */
  :global(.notif-item) {
    display: flex; gap: .75rem; align-items: flex-start;
    padding: .9rem 1rem .9rem 1.1rem;
    border-bottom: 1px solid rgba(255,255,255,.07);
    position: relative;
    transition: background .15s;
    cursor: default;
  }
  :global(.notif-item::before) {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0;
    width: 3px; background: transparent;
    transition: background .15s;
  }
  :global(.notif-item:last-child) { border-bottom: none; }
  :global(.notif-item:hover) { background: rgba(255,255,255,.04); }
  :global(.notif-item.unread) {
    background: rgba(196,92,58,.07);
    cursor: pointer;
  }
  :global(.notif-item.unread::before) { background: #C45C3A; }
  :global(.notif-item.unread:hover) { background: rgba(196,92,58,.13); }

  /* Icon */
  :global(.notif-icon) {
    width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    background: rgba(196,92,58,.18);
    border: 1px solid rgba(196,92,58,.28);
    margin-top: 2px;
  }
  :global(.notif-item.unread .notif-icon) {
    background: rgba(196,92,58,.28);
    border-color: rgba(196,92,58,.5);
  }

  /* Body */
  :global(.notif-body) { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: .4rem; }

  /* Score + tiempo en la misma fila */
  :global(.notif-top) {
    display: flex; align-items: center; justify-content: space-between;
    gap: .5rem;
  }
  :global(.notif-score) {
    display: inline-flex; align-items: center; gap: .3rem;
    font-size: .73rem; font-weight: 800; padding: .24rem .58rem;
    border-radius: 20px; white-space: nowrap; flex-shrink: 0;
    letter-spacing: .03em; line-height: 1;
  }
  :global(.notif-score::before) {
    content: ''; display: block;
    width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
  }
  :global(.notif-score.high) {
    background: rgba(52,199,89,.16); color: #5dd99a;
    border: 1px solid rgba(52,199,89,.28);
  }
  :global(.notif-score.high::before) { background: #5dd99a; }
  :global(.notif-score.medium) {
    background: rgba(255,179,64,.14); color: #f5c46a;
    border: 1px solid rgba(255,179,64,.28);
  }
  :global(.notif-score.medium::before) { background: #f5c46a; }
  :global(.notif-score.low) {
    background: rgba(255,255,255,.08); color: rgba(245,220,200,.6);
    border: 1px solid rgba(255,255,255,.12);
  }
  :global(.notif-score.low::before) { background: rgba(245,220,200,.45); }

  /* Tiempo alineado a la derecha junto al score */
  :global(.notif-time-inline) {
    font-size: .68rem; font-weight: 600;
    color: rgba(245,220,200,.28); letter-spacing: .01em;
    margin-left: auto; flex-shrink: 0;
  }

  /* Mensaje */
  :global(.notif-msg) {
    font-size: .84rem; font-weight: 500;
    color: rgba(245,220,200,.68); line-height: 1.5;
    margin: 0; word-break: break-word;
  }
  :global(.notif-item.unread .notif-msg) { color: rgba(245,220,200,.9); font-weight: 600; }

  /* Meta row */
  :global(.notif-meta) {
    display: flex; align-items: center; gap: .45rem; margin-top: .05rem;
  }
  :global(.notif-unread-dot) {
    width: 5px; height: 5px; border-radius: 50%;
    background: #C45C3A; display: none; flex-shrink: 0;
  }
  :global(.notif-item.unread .notif-unread-dot) { display: block; }

  /* Avatar + dropdown */
  .nav-avatar-wrap {
    position: relative;
  }
  .nav-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--terra);
    border: 2px solid rgba(255, 255, 255, 0.3);
    color: white;
    font-weight: 800;
    font-size: 0.8rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      border-color 0.2s,
      transform 0.15s;
    overflow: hidden;
    padding: 0;
  }
  .nav-avatar:hover {
    border-color: white;
    transform: scale(1.06);
  }
  .nav-avatar-img { width: 100%; height: 100%; object-fit: cover; }

  .nav-user-dropdown {
    display: none;
    flex-direction: column;
    position: absolute;
    top: calc(100% + 0.65rem);
    right: 0;
    background: #1c0e07;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    padding: 0.6rem;
    min-width: 180px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.45);
    animation: fadeUp 0.18s ease both;
  }
  .nav-user-dropdown.open {
    display: flex;
  }
  .dropdown-name {
    font-size: 0.82rem;
    font-weight: 700;
    color: rgba(245, 220, 200, 0.7);
    padding: 0.35rem 0.6rem 0.2rem;
  }
  .dropdown-divider {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin: 0.4rem 0;
  }
  .dropdown-item {
    display: block;
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    font-family: "Nunito", sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: rgba(245, 220, 200, 0.85);
    padding: 0.45rem 0.6rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .dropdown-item:hover { background: rgba(255,255,255,.07); color: #F5EAE0; }
  .dropdown-logout {
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    font-family: "Nunito", sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: #f0b89a;
    padding: 0.45rem 0.6rem;
    border-radius: 8px;
    transition:
      background 0.15s,
      color 0.15s;
  }
  .dropdown-logout:hover {
    background: rgba(196, 92, 58, 0.2);
    color: white;
  }

  .mobile-logout {
    background: none;
    border: none;
    cursor: pointer;
    font-family: "Nunito", sans-serif;
    text-align: left;
    width: 100%;
  }

  /* Burger */
  .nav-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav-burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: white;
    border-radius: 2px;
    transition: all 0.3s;
  }

  /* Mobile menu */
  .nav-mobile {
    display: none;
    flex-direction: column;
    gap: 0;
    position: absolute;
    top: 72px;
    left: 0;
    right: 0;
    background: rgba(20, 8, 3, 0.97);
    backdrop-filter: blur(12px);
    z-index: 50;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .nav-mobile a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    padding: 1rem 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition:
      color 0.2s,
      background 0.2s;
  }
  .nav-mobile a:hover {
    color: white;
    background: rgba(255, 255, 255, 0.05);
  }
  .nav-cta-mobile {
    color: var(--terra) !important;
    font-weight: 800 !important;
  }
  .nav-mobile.open {
    display: flex;
  }

  @media (max-width: 768px) {
    .nav {
      padding: 1.2rem 1.4rem;
    }
    .nav-links {
      display: none;
    }
    .nav-burger {
      display: flex;
    }
  }

  @keyframes fadeDown {
    from {
      opacity: 0;
      transform: translateY(-18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  import { getSession, logout, onAuthChange } from "../lib/auth";
  import { apiFetch } from "../lib/api";

  // ── Burger ──
  const burger = document.getElementById("nav-burger");
  const mobile = document.getElementById("nav-mobile");
  burger?.addEventListener("click", () => {
    const isOpen = mobile?.classList.toggle("open");
    burger.setAttribute("aria-expanded", String(isOpen));
  });

  // ── Auth state ──
  function applyAuth(user: { name: string; initials: string; fotoPerfilUrl?: string | null } | null) {
    const guestEls = document.querySelectorAll<HTMLElement>('[data-auth="guest"]');
    const userEls  = document.querySelectorAll<HTMLElement>('[data-auth="user"]');
    guestEls.forEach((el) => { el.style.display = user ? "none" : ""; });
    userEls.forEach((el)  => { el.style.display = user ? "" : "none"; });

    if (user) {
      const initEl = document.getElementById("nav-initials");
      const nameEl = document.getElementById("nav-user-name");
      const imgEl  = document.getElementById("nav-avatar-img") as HTMLImageElement | null;
      if (nameEl) nameEl.textContent = user.name;

      if (imgEl && user.fotoPerfilUrl) {
        imgEl.src = user.fotoPerfilUrl;
        imgEl.alt = user.name;
        imgEl.style.display = "block";
        if (initEl) initEl.style.display = "none";
      } else {
        if (initEl) { initEl.textContent = user.initials; initEl.style.display = ""; }
        if (imgEl)  imgEl.style.display = "none";
      }
    }
  }

  // Aplica estado inicial (evita flash)
  applyAuth(getSession());
  // Reacciona a cambios en tiempo real
  onAuthChange(applyAuth);

  // ── Avatar dropdown toggle ──
  const avatarBtn = document.getElementById("nav-avatar-btn");
  const dropdown = document.getElementById("nav-user-dropdown");
  avatarBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    const isOpen = dropdown?.classList.toggle("open");
    avatarBtn.setAttribute("aria-expanded", String(isOpen));
  });
  document.addEventListener("click", () => dropdown?.classList.remove("open"));

  // ── Logout ──
  async function doLogout() {
    await logout();
    window.location.href = "/";
  }
  document
    .getElementById("nav-logout-btn")
    ?.addEventListener("click", doLogout);
  document
    .getElementById("nav-mobile-logout")
    ?.addEventListener("click", doLogout);

  // ── Notificaciones ──
  const bellBtn    = document.getElementById("nav-bell-btn");
  const bellBadge  = document.getElementById("nav-bell-badge");
  const notifDrop  = document.getElementById("nav-notif-dropdown");
  const notifList  = document.getElementById("nav-notif-list");
  const readAllBtn = document.getElementById("nav-read-all");

  function timeAgo(isoDate: string): string {
    const diff = Date.now() - new Date(isoDate).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1)  return "Ahora";
    if (mins < 60) return `Hace ${mins} min`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24)  return `Hace ${hrs} h`;
    return `Hace ${Math.floor(hrs / 24)} d`;
  }

  async function fetchUnreadCount() {
    try {
      if (!getSession()) return;
      const data = await apiFetch("/api/usuarios/me/notificaciones/no-leidas");
      const count = (data as any)?.count ?? 0;
      if (bellBadge) {
        bellBadge.textContent = count > 9 ? "9+" : String(count);
        bellBadge.style.display = count > 0 ? "flex" : "none";
      }
    } catch { /* silencioso */ }
  }

  const PAW_SVG = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="color:#F0B89A"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>`;

  function scoreInfo(msg: string): { pct: number; label: string; cls: string } {
    const m = msg.match(/(\d+)%/);
    const pct = m ? parseInt(m[1]) : 0;
    if (pct >= 80) return { pct, label: `${pct}% coincidencia`, cls: 'high' };
    if (pct >= 60) return { pct, label: `${pct}% coincidencia`, cls: 'medium' };
    return { pct, label: pct ? `${pct}% coincidencia` : 'Coincidencia', cls: 'low' };
  }

  function renderMsg(msg: string): string {
    return msg
      .replace(/con un \d+% de similitud/, '')
      .replace(/\s{2,}/g, ' ')
      .trim();
  }

  async function fetchNotificaciones() {
    if (!notifList) return;
    try {
      const items: Array<{
        id: string; mensaje: string; leida: boolean;
        coincidenciaId: string | null; createdAt: string;
      }> = await apiFetch("/api/usuarios/me/notificaciones");

      if (!items || items.length === 0) {
        notifList.innerHTML = `
          <div class="notif-empty">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            Sin notificaciones por ahora
          </div>`;
        return;
      }

      notifList.innerHTML = items.map(n => {
        const { label, cls } = scoreInfo(n.mensaje);
        const body = renderMsg(n.mensaje);
        return `
        <div class="notif-item ${n.leida ? '' : 'unread'}" data-id="${n.id}">
          <div class="notif-icon">${PAW_SVG}</div>
          <div class="notif-body">
            <div class="notif-top">
              <span class="notif-score ${cls}">${label}</span>
              <span class="notif-time-inline">${timeAgo(n.createdAt)}</span>
            </div>
            <p class="notif-msg">${body}</p>
            <div class="notif-meta">
              <span class="notif-unread-dot"></span>
            </div>
          </div>
        </div>`;
      }).join('');

      notifList.querySelectorAll<HTMLElement>(".notif-item.unread").forEach(el => {
        el.addEventListener("click", async () => {
          const id = el.dataset.id;
          if (!id) return;
          try {
            await apiFetch(`/api/usuarios/me/notificaciones/${id}/leer`, { method: "PATCH" });
            el.classList.remove("unread");
            await fetchUnreadCount();
          } catch { /* silencioso */ }
        });
      });
    } catch {
      notifList.innerHTML = `<div class="notif-empty">Error al cargar notificaciones</div>`;
    }
  }

  bellBtn?.addEventListener("click", async (e) => {
    e.stopPropagation();
    const isOpen = notifDrop?.classList.toggle("open");
    bellBtn.setAttribute("aria-expanded", String(isOpen));
    document.getElementById("nav-user-dropdown")?.classList.remove("open");
    if (isOpen) await fetchNotificaciones();
  });

  readAllBtn?.addEventListener("click", async (e) => {
    e.stopPropagation();
    try {
      await apiFetch("/api/usuarios/me/notificaciones/leer-todas", { method: "PATCH" });
      await fetchNotificaciones();
      await fetchUnreadCount();
    } catch { /* silencioso */ }
  });

  document.addEventListener("click", () => notifDrop?.classList.remove("open"));

  onAuthChange((user) => {
    if (user) {
      fetchUnreadCount();
      setInterval(fetchUnreadCount, 30_000);
    }
  });

  if (getSession()) fetchUnreadCount();
</script>
