---
// src/pages/acceder.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Acceder — Sanos & Salvos" description="Inicia sesión o crea tu cuenta en Sanos & Salvos">

  <div class="auth-page">

    <!-- Left panel — branding -->
    <div class="auth-left">
      <div class="auth-left-inner">
        <a href="/" class="logo">
          <div class="logo-mark">🐾</div>
          <span class="logo-text">Sanos &amp; Salvos</span>
        </a>
        <blockquote class="auth-quote">
          <p>"Gracias a la comunidad encontramos a Luna en menos de 6 horas. No lo hubiera logrado solo."</p>
          <footer>
            <div class="quote-avatar">🐕</div>
            <div>
              <strong>Carlos M.</strong>
              <span>Ciudad de México</span>
            </div>
          </footer>
        </blockquote>
        <div class="auth-stat-row">
          <div class="auth-stat">
            <span class="stat-n">2.4k+</span>
            <span class="stat-l">Reuniones</span>
          </div>
          <div class="auth-stat">
            <span class="stat-n">380</span>
            <span class="stat-l">Reportes activos</span>
          </div>
          <div class="auth-stat">
            <span class="stat-n">48h</span>
            <span class="stat-l">Tiempo promedio</span>
          </div>
        </div>
      </div>
      <!-- background photo -->
      <div class="auth-left-bg"></div>
      <div class="auth-left-overlay"></div>
    </div>

    <!-- Right panel — form -->
    <div class="auth-right">
      <div class="auth-form-wrap">

        <!-- Tabs -->
        <div class="tabs" role="tablist">
          <button class="tab active" id="tab-login" role="tab" aria-selected="true" aria-controls="panel-login">
            Iniciar sesión
          </button>
          <button class="tab" id="tab-registro" role="tab" aria-selected="false" aria-controls="panel-registro">
            Registrarse
          </button>
          <div class="tab-indicator"></div>
        </div>

        <!-- ── LOGIN PANEL ── -->
        <div class="tab-panel active" id="panel-login" role="tabpanel" aria-labelledby="tab-login">
          <h1 class="form-title">Bienvenido de vuelta</h1>
          <p class="form-sub">Ingresa a tu cuenta para gestionar tus reportes.</p>

          <!-- Google -->
          <button class="btn-google" id="btn-google-login" type="button">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/>
              <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#34A853"/>
              <path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/>
              <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z" fill="#EA4335"/>
            </svg>
            Continuar con Google
          </button>

          <p class="auth-only-google">
            Sanos &amp; Salvos usa exclusivamente Google para autenticar usuarios.<br />
            No almacenamos contraseñas.
          </p>
        </div>

        <!-- ── REGISTRO PANEL ── -->
        <div class="tab-panel" id="panel-registro" role="tabpanel" aria-labelledby="tab-registro">
          <h1 class="form-title">Crea tu cuenta</h1>
          <p class="form-sub">Únete a la comunidad y ayuda a reunir mascotas con sus familias.</p>

          <!-- Google -->
          <button class="btn-google" id="btn-google-registro" type="button">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/>
              <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#34A853"/>
              <path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/>
              <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z" fill="#EA4335"/>
            </svg>
            Registrarse con Google
          </button>

          <p class="auth-only-google">
            Tu cuenta se crea automáticamente la primera vez que inicias sesión con Google.<br />
            No se requiere contraseña.
          </p>
        </div>

      </div>
    </div>
  </div>

</BaseLayout>

<style>
  /* ── PAGE LAYOUT ── */
  .auth-page {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100svh;
    background: var(--cream);
  }

  /* ── LEFT PANEL ── */
  .auth-left {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }
  .auth-left-bg {
    position: absolute; inset: 0;
    background-image: url('https://images.unsplash.com/photo-1601758174493-ab843c9e0d66?w=1000&q=85&auto=format&fit=crop');
    background-size: cover;
    background-position: center;
  }
  .auth-left-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(15,6,2,0.92) 0%, rgba(15,6,2,0.3) 50%, rgba(196,92,58,0.2) 100%);
  }
  .auth-left-inner {
    position: relative; z-index: 2;
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    width: 100%;
  }

  .logo {
    display: flex; align-items: center; gap: 0.55rem;
    text-decoration: none; color: white; width: fit-content;
  }
  .logo-mark {
    width: 36px; height: 36px; background: var(--terra); border-radius: 10px;
    display: flex; align-items: center; justify-content: center; font-size: 1.1rem;
    box-shadow: 0 2px 12px rgba(196,92,58,0.5);
  }
  .logo-text { font-family: 'Fraunces', serif; font-weight: 700; font-size: 1.2rem; }

  .auth-quote {
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 16px;
    padding: 1.5rem;
  }
  .auth-quote p {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 1rem;
    color: white;
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .auth-quote footer {
    display: flex; align-items: center; gap: 0.75rem;
  }
  .quote-avatar {
    width: 38px; height: 38px;
    background: var(--terra-l);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem;
  }
  .auth-quote strong { display: block; color: white; font-size: 0.9rem; }
  .auth-quote span { color: rgba(255,255,255,0.5); font-size: 0.78rem; }

  .auth-stat-row {
    display: flex; gap: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .auth-stat { display: flex; flex-direction: column; gap: 0.15rem; }
  .stat-n { font-family: 'Fraunces', serif; font-weight: 700; font-size: 1.4rem; color: #F0B89A; }
  .stat-l { font-size: 0.72rem; font-weight: 700; color: rgba(255,255,255,0.45); text-transform: uppercase; letter-spacing: 0.06em; }

  /* ── RIGHT PANEL ── */
  .auth-right {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
    overflow-y: auto;
  }
  .auth-form-wrap {
    width: 100%;
    max-width: 420px;
  }

  /* ── TABS ── */
  .tabs {
    display: flex;
    position: relative;
    background: var(--sand);
    border-radius: 14px;
    padding: 4px;
    margin-bottom: 2rem;
    gap: 2px;
  }
  .tab {
    flex: 1;
    padding: 0.65rem 1rem;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--brown-m);
    border-radius: 10px;
    position: relative;
    z-index: 1;
    transition: color 0.25s;
  }
  .tab.active { color: var(--brown); }
  .tab-indicator {
    position: absolute;
    top: 4px; left: 4px;
    width: calc(50% - 4px);
    height: calc(100% - 8px);
    background: white;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(45,27,18,0.1);
    transition: transform 0.3s cubic-bezier(.34,1.2,.64,1);
  }
  .tabs.registro .tab-indicator { transform: translateX(calc(100% + 2px)); }

  /* ── PANELS ── */
  .tab-panel { display: none; animation: fadeUp 0.35s ease both; }
  .tab-panel.active { display: block; }

  .form-title {
    font-family: 'Fraunces', serif;
    font-weight: 900;
    font-size: 1.8rem;
    letter-spacing: -0.02em;
    color: var(--brown);
    margin-bottom: 0.4rem;
  }
  .form-sub {
    font-size: 0.92rem;
    color: var(--brown-m);
    margin-bottom: 1.8rem;
    line-height: 1.5;
  }

  /* ── GOOGLE BUTTON ── */
  .btn-google {
    width: 100%;
    display: flex; align-items: center; justify-content: center; gap: 0.75rem;
    padding: 0.85rem;
    background: white;
    border: 1.5px solid #E0D8CF;
    border-radius: 12px;
    font-family: 'Nunito', sans-serif;
    font-weight: 700; font-size: 0.95rem;
    color: var(--brown);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, transform 0.15s;
    box-shadow: 0 2px 8px rgba(45,27,18,0.06);
  }
  .btn-google:hover {
    background: #F8F4EE;
    border-color: #C8B8A8;
    transform: translateY(-1px);
  }

  /* ── DIVIDER ── */
  .divider {
    display: flex; align-items: center; gap: 1rem;
    margin: 1.4rem 0;
    color: var(--brown-m); font-size: 0.8rem; font-weight: 600;
  }
  .divider::before, .divider::after {
    content: ''; flex: 1;
    height: 1px; background: #E0D8CF;
  }

  /* ── FORM FIELDS ── */
  .auth-form { display: flex; flex-direction: column; gap: 1.1rem; }
  .fields-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }

  .field { display: flex; flex-direction: column; gap: 0.4rem; }
  .field-header { display: flex; align-items: center; justify-content: space-between; }

  label {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--brown);
    letter-spacing: 0.01em;
  }
  .forgot {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--terra);
    text-decoration: none;
    transition: color 0.2s;
  }
  .forgot:hover { color: var(--terra-d); }

  input[type="text"],
  input[type="email"],
  input[type="password"] {
    width: 100%;
    padding: 0.75rem 1rem;
    background: white;
    border: 1.5px solid #E0D8CF;
    border-radius: 12px;
    font-family: 'Nunito', sans-serif;
    font-size: 0.95rem;
    color: var(--brown);
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
  }
  input::placeholder { color: #B8A898; }
  input:focus {
    border-color: var(--terra);
    box-shadow: 0 0 0 3px rgba(196,92,58,0.12);
  }
  input:invalid:not(:placeholder-shown) {
    border-color: #E05C3A;
    box-shadow: 0 0 0 3px rgba(224,92,58,0.10);
  }

  .input-wrap { position: relative; }
  .input-wrap input { padding-right: 2.8rem; }
  .toggle-pass {
    position: absolute; right: 0.8rem; top: 50%; transform: translateY(-50%);
    background: none; border: none; cursor: pointer; font-size: 1rem; opacity: 0.5;
    transition: opacity 0.2s; line-height: 1;
  }
  .toggle-pass:hover { opacity: 1; }

  /* Password strength */
  .strength-bar {
    height: 4px; background: #E0D8CF; border-radius: 999px; margin-top: 0.4rem; overflow: hidden;
  }
  .strength-fill {
    height: 100%; width: 0%; border-radius: 999px;
    transition: width 0.3s ease, background 0.3s ease;
  }
  .strength-label { font-size: 0.72rem; font-weight: 700; color: var(--brown-m); margin-top: 0.2rem; display: block; }

  /* Checkbox */
  .checkbox-field {
    display: flex; align-items: flex-start; gap: 0.6rem;
    font-size: 0.82rem; color: var(--brown-m); font-weight: 600; cursor: pointer; line-height: 1.4;
  }
  .checkbox-field input[type="checkbox"] {
    width: 16px; height: 16px; flex-shrink: 0; margin-top: 1px;
    accent-color: var(--terra); border-radius: 4px; cursor: pointer;
  }
  .checkbox-field a { color: var(--terra); text-decoration: none; }
  .checkbox-field a:hover { text-decoration: underline; }

  /* Submit */
  .btn-submit {
    width: 100%;
    padding: 0.95rem;
    background: var(--terra);
    color: white;
    border: none;
    border-radius: 12px;
    font-family: 'Nunito', sans-serif;
    font-weight: 800; font-size: 1rem;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(196,92,58,0.35);
    transition: background 0.2s, transform 0.18s cubic-bezier(.34,1.56,.64,1), box-shadow 0.18s;
    margin-top: 0.4rem;
  }
  .btn-submit:hover {
    background: var(--terra-d);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(196,92,58,0.45);
  }

  /* ── SOLO GOOGLE ── */
  .auth-only-google {
    margin-top: 1.2rem;
    font-size: 0.78rem;
    color: var(--brown-m);
    line-height: 1.6;
    text-align: center;
    opacity: 0.7;
  }

  /* ── ERROR DE AUTH ── */
  .auth-error-banner {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.85rem 1rem;
    background: rgba(224,92,58,0.1);
    border: 1px solid rgba(224,92,58,0.3);
    border-radius: 10px;
    font-size: 0.85rem;
    color: #9E3820;
    font-weight: 600;
    margin-bottom: 1.2rem;
    animation: fadeUp 0.3s ease both;
  }

  /* ── LOADING OVERLAY ── */
  .auth-loading {
    position: fixed; inset: 0; z-index: 999;
    background: rgba(253,248,240,0.9);
    backdrop-filter: blur(6px);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 1rem;
    opacity: 0; pointer-events: none;
    transition: opacity 0.25s;
  }
  .auth-loading.show { opacity: 1; pointer-events: auto; }
  .auth-loading-paw {
    font-size: 2.5rem;
    animation: spin 1.2s linear infinite;
  }
  .auth-loading p {
    font-family: 'Fraunces', serif;
    font-size: 1.1rem;
    color: var(--brown);
    font-weight: 700;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .auth-page { grid-template-columns: 1fr; }
    .auth-left { display: none; }
    .auth-right { padding: 2rem 1.2rem; align-items: flex-start; padding-top: 3rem; }
    .fields-row { grid-template-columns: 1fr; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  import { login, getSession, GOOGLE_AUTH_URL } from '../lib/auth';

  // ── Si ya hay sesión activa, redirigir directo al mapa ──
  if (getSession()) {
    window.location.replace('/mapa');
  }

  // ── Inyectar loading overlay en el DOM ──
  const loadingEl = document.createElement('div');
  loadingEl.className = 'auth-loading';
  loadingEl.innerHTML = `
    <div class="auth-loading-paw">🐾</div>
    <p>Iniciando sesión…</p>
  `;
  document.body.appendChild(loadingEl);

  function showLoading() { loadingEl.classList.add('show'); }

  function showError(msg: string) {
    // Insertar banner de error en ambos paneles
    document.querySelectorAll('.tab-panel.active').forEach(panel => {
      const existing = panel.querySelector('.auth-error-banner');
      if (existing) existing.remove();
      const banner = document.createElement('div');
      banner.className = 'auth-error-banner';
      banner.innerHTML = `⚠️ ${msg}`;
      panel.insertBefore(banner, panel.firstChild);
    });
  }

  // ── Leer ?token= de la URL (vuelta desde Google OAuth2) ──
  const params = new URLSearchParams(window.location.search);
  const token  = params.get('token');
  const error  = params.get('error');

  if (token) {
    showLoading();
    login(token)
      .then(() => {
        // Limpiar token de la URL antes de redirigir
        window.location.replace('/mapa');
      })
      .catch((err: unknown) => {
        loadingEl.classList.remove('show');
        const msg = err instanceof Error ? err.message : 'Error al iniciar sesión. Intenta nuevamente.';
        showError(msg);
        // Limpiar ?token= de la URL sin recargar
        history.replaceState(null, '', window.location.pathname);
      });
  } else if (error) {
    showError('El inicio de sesión fue cancelado o falló. Por favor intenta nuevamente.');
    history.replaceState(null, '', window.location.pathname);
  }

  // ── Botones de Google → redirigir al endpoint OAuth2 ──
  document.getElementById('btn-google-login')?.addEventListener('click', () => {
    showLoading();
    window.location.href = GOOGLE_AUTH_URL;
  });
  document.getElementById('btn-google-registro')?.addEventListener('click', () => {
    showLoading();
    window.location.href = GOOGLE_AUTH_URL;
  });

  // ── TABS ──
  const tabs     = document.querySelectorAll('.tab');
  const panels   = document.querySelectorAll('.tab-panel');
  const tabsWrap = document.querySelector('.tabs');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.id === 'tab-registro' ? 'registro' : 'login';
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      panels.forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      document.getElementById(`panel-${target}`)?.classList.add('active');
      if (target === 'registro') tabsWrap?.classList.add('registro');
      else tabsWrap?.classList.remove('registro');
    });
  });
</script>
